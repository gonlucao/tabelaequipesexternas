<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Ranking do Mês</title>

<style>
body {
  font-family: Arial;
  background:#f5f7fb;
  padding:20px;
}

.card {
  background:white;
  padding:20px;
  border-radius:16px;
  max-width:800px;
  margin:auto;
}

table {
  width:100%;
  border-collapse:collapse;
}

th,td {
  padding:10px;
  border-bottom:1px solid #eee;
  text-align:center;
}

.meta-ok{color:#16a34a;font-weight:bold;}
.meta-bad{color:#dc2626;}
</style>
</head>

<body>

<div class="card">
  <h2>🏆 Ranking - Mês Atual</h2>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Equipe</th>
        <th>Pontuação</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody id="ranking"></tbody>
  </table>
</div>

<script>

const abas = ["1836732217","576248296","1758926410"];

async function carregarMes(gid){
  const url = `https://docs.google.com/spreadsheets/d/1KAmeD9jbBX8JssWWeWG3kR03J4zVEjQDx--ojQIFSmg/gviz/tq?tqx=out:json&gid=${gid}`;
  const res = await fetch(url);
  const text = await res.text();
  const json = JSON.parse(text.substring(text.indexOf("{"), text.lastIndexOf("}")+1));
  return json.table.rows;
}

async function carregarRanking(){

  let dados = {};

  const resultados = await Promise.all(abas.map(gid => carregarMes(gid)));

  resultados.forEach((rows, i)=>{
    rows.forEach((r,index)=>{
      if(index===0) return;

      let nome = r.c[0]?.v;
      if(!nome) return;

      let total = Number(r.c[19]?.v)||0;

      if(!dados[nome]) dados[nome]=[0,0,0];
      dados[nome][i]=total;
    });
  });

  // pega último mês
  let ranking = Object.keys(dados).map(nome=>{
    return {
      nome,
      valor: dados[nome][2] || 0
    };
  });

  ranking.sort((a,b)=>b.valor - a.valor);

  render(ranking);
}

function render(lista){
  let tbody = document.getElementById("ranking");
  tbody.innerHTML="";

  lista.forEach((e,i)=>{
    let pos = i+1;
    let medalha = pos==1?"🥇":pos==2?"🥈":pos==3?"🥉":pos;

    tbody.innerHTML += `
      <tr>
        <td>${medalha}</td>
        <td>${e.nome}</td>
        <td class="${e.valor>=170?'meta-ok':'meta-bad'}">${e.valor}</td>
        <td class="${e.valor>=170?'meta-ok':'meta-bad'}">
          ${e.valor>=170?'Meta batida':'Abaixo da meta'}
        </td>
      </tr>`;
  });
}

carregarRanking();

</script>

</body>
</html>
